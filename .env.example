# Copiá este archivo a .env y completá con tu connection string real de Neon (https://neon.tech).
# DATABASE_URL: connection string "pooled" — la usa la app en runtime.
# DIRECT_URL: connection string "direct" — la usa Prisma para migraciones.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# AUTH_SECRET: clave usada por Auth.js para firmar/cifrar los tokens de sesión (JWT).
# Generala vos, por ejemplo con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# SEED_ADMIN_PASSWORD: contraseña del usuario administrador que crea prisma/seed.ts
# en entorno de desarrollo. Nunca hardcodeada en el código ni versionada con valor real.
SEED_ADMIN_PASSWORD=
